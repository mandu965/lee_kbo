# ══════════════════════════════════════════════════════════
# KBO Predictor 환경변수 템플릿
# 로컬 개발: 이 파일을 .env 로 복사 후 값 수정
# 배포:     각 서비스의 환경변수 설정 화면에 직접 입력
# ══════════════════════════════════════════════════════════

# ── 실행 환경 ────────────────────────────────────────────
# dev | production
ENV=dev

# ── 로컬 Docker 포트 (Lee Trader 충돌 방지) ───────────────
# PostgreSQL : 5433  |  Redis : 6380  |  API : 8002

# ── 데이터베이스 ──────────────────────────────────────────
# [로컬] Docker Compose 내부 연결
DATABASE_URL=postgresql+asyncpg://kbo:kbopass@db:5432/kbo_predictor

# [Supabase 배포] 아래 형식으로 교체 (Transaction Pooler 권장)
# DATABASE_URL=postgresql+asyncpg://postgres.xxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
# SSL이 필요하면 database.py의 connect_args={"ssl": True} 로 변경

# Docker Compose DB 계정 (로컬 전용)
POSTGRES_USER=kbo
POSTGRES_PASSWORD=kbopass
POSTGRES_DB=kbo_predictor

# ── Redis ─────────────────────────────────────────────────
# [로컬]
REDIS_URL=redis://redis:6379/1
# [Upstash] redis://default:PASSWORD@hostname:6379

# ── FastAPI ───────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-random-32-chars
# 허용할 프론트엔드 출처 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Next.js (프론트엔드) ──────────────────────────────────
# [로컬]
NEXT_PUBLIC_API_URL=http://localhost:8002/v1
# [Render 배포 후]
# NEXT_PUBLIC_API_URL=https://lee-kbo.onrender.com/v1

NEXT_PUBLIC_SITE_URL=https://lee-kbo-web.onrender.com

# ── Google AdSense (승인 후 설정) ─────────────────────────
# Render 프론트엔드 서비스 환경변수에도 같은 값을 설정
# 설정하면 /ads.txt가 자동으로 google.com, pub-..., DIRECT 형식으로 응답
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_AD_SLOT_BANNER=
NEXT_PUBLIC_AD_SLOT_ARTICLE=

# ── Blog polish with local Ollama ─────────────────────────
# BLOG_POLISH_ENABLED=false
# BLOG_POLISH_MODEL=qwen2.5:7b
# Local Python: http://127.0.0.1:11434
# Docker Compose on Windows/macOS: http://host.docker.internal:11434
# BLOG_POLISH_OLLAMA_URL=http://host.docker.internal:11434
# BLOG_POLISH_TIMEOUT=90
# BLOG_POLISH_TEMPERATURE=0.25
# Lower these when Ollama fails from limited RAM.
# BLOG_POLISH_NUM_CTX=2048
# BLOG_POLISH_KEEP_ALIVE=0

# ── Blog enrich/polish with Gemini ───────────────────────
# 실제 API 키는 .env 또는 배포 환경변수에만 설정하고 커밋하지 마세요.
# G_STUDIO_API_KEY=your-google-ai-studio-api-key
# BLOG_ENRICH_GEMINI_ENABLED=0
# BLOG_ENRICH_GEMINI_MODEL=gemini-1.5-flash
# BLOG_ENRICH_GEMINI_TIMEOUT=90
# BLOG_ENRICH_GEMINI_TEMPERATURE=0.2
# BLOG_POLISH_PROVIDER=ollama
# BLOG_POLISH_GEMINI_MODEL=gemini-1.5-flash
# BLOG_OUTPUT_KEEP_LATEST_ONLY=1
